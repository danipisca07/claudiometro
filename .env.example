# Porta del server HTTP
PORT=4317

# Imposta a 1/true per disabilitare l'auto-refresh del token OAuth.
# Se disabilitato e il token e' scaduto, le API rispondono 401.
DISABLE_REFRESH=0

# Override opzionale della cartella di config di Claude Code.
# Default: ~/.claude  (rispetta anche la env CLAUDE_CONFIG_DIR se gia' presente)
# CLAUDE_CONFIG_DIR=
