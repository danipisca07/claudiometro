# HTTP server port
PORT=4317

# Claude Code credentials directory (default: ~/.claude)
# In the container, point it to the mounted volume, e.g. /config
CLAUDE_CONFIG_DIR=

# Runtime data directory (scheduled pings). Default: ./data next to the code.
# In the container, point it to the mounted volume, e.g. /data
CLAUDIOMETRO_DATA_DIR=

# Secret token for the /admin/* endpoints (remote credentials upload).
# REQUIRED to enable /admin/*. Empty = endpoints disabled.
# Generate a long, random value.
CLAUDIOMETRO_ADMIN_TOKEN=
