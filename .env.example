# Porta del server HTTP
PORT=4317

# Imposta a 1/true per disabilitare l'auto-refresh del token OAuth.
# Se disabilitato e il token e' scaduto, le API rispondono 401.
DISABLE_REFRESH=0

# Override opzionale della cartella di config di Claude Code.
# Default: ~/.claude  (rispetta anche la env CLAUDE_CONFIG_DIR se gia' presente)
# CLAUDE_CONFIG_DIR=

# Cartella dove persistere i ping programmati.
# Default: ./data
# CLAUDIOMETRO_DATA_DIR=

# Segreto per gli endpoint /admin/* (upload remoto delle credenziali).
# Vuoto = endpoint admin DISABILITATI (fail-closed). Necessario per il deploy
# su NAS/Docker. Usa un valore lungo e casuale; non esporlo mai pubblicamente.
# CLAUDIOMETRO_ADMIN_TOKEN=
